## Frontend (Vite) environment variables
## Copy to .env.local (recommended) and adjust values.

# Backend base URL (no trailing slash). Examples:
# - Local: http://localhost:3000
# - Remote: https://api.tu-dominio.com
VITE_API_BASE_URL=http://localhost:3000

# Optional maintenance mode
VITE_MODO_MANTENIMIENTO=false

# Optional agency logo URL/path (used in maintenance screen)
# Example: /logo.png
VITE_AGENCY_LOGO=

